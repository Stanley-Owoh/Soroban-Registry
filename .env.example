# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=soroban_registry

# API
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/soroban_registry
RUST_LOG=info
JWT_SECRET=changeme_use_at_least_32_chars_of_random_data
PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS — comma-separated list of allowed browser origins (scheme + host + port,
# no trailing slash, no path). Each entry must match a Request Origin exactly.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://soroban-registry.vercel.app
# If unset, defaults to: http://localhost:3000,https://soroban-registry.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Graceful shutdown
SHUTDOWN_TIMEOUT=30

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme_strong_password

# Alertmanager (optional)
# SLACK_WEBHOOK_URL=
# PAGERDUTY_SERVICE_KEY=

# DB pool tuning (optional, auto-sized by default)
# DB_MAX_POOL_SIZE=20
